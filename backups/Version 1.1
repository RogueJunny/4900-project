<p style="border-style:none;border-width:0px;padding-top:0;padding-right:0;padding-bottom:0;padding-left:0;font-size:2rem;font-style:normal;font-weight:700">Fendja Larivaux</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"typography":{"fontSize":"1.5rem"}}} -->
<p style="font-size:1.5rem">Academic Program Specialist</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"typography":{"fontStyle":"italic","fontWeight":"100","fontSize":"1.25rem"}}} -->
<p style="font-size:1.25rem;font-style:italic;font-weight:100">2114 Ingersoll Hall | 718.951.5000×2045 | fendja.larivaux@brooklyn.cuny.edu</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"typography":{"fontSize":"1.5rem"}}} -->
<p style="font-size:1.5rem">Fendja Larivaux is an Academic Program Specialist, and the mind behind Brooklyn College CIS Connect. She is an Experienced Technical Program Manager with a demonstrated history of working in the higher education industry, and a Master’s Degree focused in Higher Education/Higher Education Administration.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"placeholder":"Content…","style":{"typography":{"fontSize":"1.5rem"}}} -->
<p style="font-size:1.5rem">Center for an Urban Future Article</p>
<!-- /wp:paragraph --></div></div>
<!-- /wp:media-text -->

