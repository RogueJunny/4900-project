.rt-paragraph-block {
  /* Your existing paragraph styles */
}

.rt-paragraph-block a {
  text-decoration: none; /* Remove default underline */
  color: currentColor;
  transition: color 0.3s ease, border-color 0.3s ease;
  outline: none !important;
  -webkit-tap-highlight-color: transparent;
  letter-spacing: 3px; /* Further text spacing */
  position: relative;
  padding-right: 25px; /* Increased space for arrow */
  border-bottom: 3px solid #FEA240; /* Thicker underline */
  display: inline-block;
}

.rt-paragraph-block a:focus {
  outline: none !important;
}

.rt-paragraph-block a:active {
  outline: none !important;
}

.rt-paragraph-block a:hover {
  color: #FEA240;
  border-bottom-color: #F24131; /* Changes underline color on hover */
}

.rt-paragraph-block a::after {
  content: ">";
  color: #F24131;
  position: absolute;
  right: 0;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none; /* Prevents arrow from interfering with hover */
}

.rt-paragraph-block a:hover::after {
  opacity: 1;
}

/* Ensure underline covers the entire link including the space for arrow */
.rt-paragraph-block a::before {
  content: "";
  position: absolute;
  bottom: -3px;
  left: 0;
  right: 0;
  height: 3px;
  background-color: inherit;
  display: none;
}










