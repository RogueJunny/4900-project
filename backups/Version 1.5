<!-- /wp:list-item -->

<!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
<li style="font-size:1.25rem">Unwillingness to discuss salary or benefits.</li>
<!-- /wp:list-item -->

<!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
