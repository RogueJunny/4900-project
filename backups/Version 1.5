		<wp:meta_value><![CDATA[/* Category-based colors - Final Complete Version */

.opportunity-feed {
    padding: 60px 20px;
    background: transparent;
}

/* Base post styling with balanced shadow */
.opportunity-feed .wp-block-group {
    padding: 25px 50px 40px 50px !important;
    margin-bottom: 30px;
    margin-left: auto !important;
    margin-right: auto !important;
    border-radius: 0 !important;
    max-width: 1400px !important;
    width: 95% !important;
    box-sizing: border-box;
    box-shadow: 0 15px 30px -10px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.08) inset !important;
    transition: all 0.3s ease !important;
    overflow: hidden !important;
}

/* Hover effect - slightly deeper */
.opportunity-feed .wp-block-group:hover {
    box-shadow: 0 20px 40px -12px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.1) inset !important;
    transform: translateY(-5px) !important;
}

/* Featured Image - 30% width, Left-Aligned, NO rounded corners */
.opportunity-feed .wp-block-group .wp-block-post-featured-image {
    float: left !important;
    margin: 0 25px 20px 0 !important;
    width: 35% !important;
    max-width: 35% !important;
}

.opportunity-feed .wp-block-group .wp-block-post-featured-image img {
    max-width: 100% !important;
    width: 100% !important;
    height: auto !important;
    border-radius: 0 !important;
    object-fit: cover !important;
}

/* Title - 3rem, UNBOLDED */
.opportunity-feed .wp-block-group .wp-block-post-title {
    font-size: 3rem !important;
    margin-bottom: 10px !important;
    font-weight: normal !important;
    width: 100% !important;
    display: block !important;
    clear: both !important;
}

/* Date - full width, not floated, stays above */
.opportunity-feed .wp-block-group .wp-block-post-date,
.opportunity-feed .wp-block-group .wp-block-post-date a {
    font-size: 1.25rem !important;
    margin-top: 0 !important;
    margin-bottom: 10px !important;
    display: block !important;
    width: 100% !important;
    clear: both !important;
}

/* Excerpt - 1.5rem FONT SIZE */
.opportunity-feed .wp-block-group .wp-block-post-excerpt {
    display: block !important;
    overflow: hidden !important;
    margin-bottom: 10px !important;
}

.opportunity-feed .wp-block-group .wp-block-post-excerpt p {
    font-size: 1.5rem !important;
    line-height: 1.4 !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
}

/* Read More button styling - 1.75rem, WITH LETTER SPACING, NO BOLD */
.opportunity-feed .wp-block-group .wp-block-read-more {
    font-size: 1.75rem !important;
    display: inline-block !important;
    margin-top: 0 !important;
    margin-bottom: 10px !important;
    background-color: #ffffff !important;
    color: #000000 !important;
    padding: 8px 20px !important;
    text-decoration: none !important;
    border: 1px solid #ffffff !important;
    transition: all 0.3s ease !important;
    font-weight: normal !important;
    letter-spacing: 2px !important;
}

/* Read More button hover - Black box, White text */
.opportunity-feed .wp-block-group .wp-block-read-more:hover {
    background-color: #000000 !important;
    color: #ffffff !important;
    border-color: #000000 !important;
    transform: translateY(-2px) !important;
    font-weight: normal !important;
    letter-spacing: 2px !important;
}

/* Remove the "..." after Read More */
.opportunity-feed .wp-block-group .wp-block-read-more::after {
    content: "" !important;
}

/* OVERRIDE any category colors on the Read More button */
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-read-more,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-read-more,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-read-more {
    background-color: #ffffff !important;
    color: #000000 !important;
    border: 1px solid #ffffff !important;
    font-weight: normal !important;
    letter-spacing: 2px !important;
}

.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-read-more:hover,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-read-more:hover,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-read-more:hover {
    background-color: #000000 !important;
    color: #ffffff !important;
    border-color: #000000 !important;
    font-weight: normal !important;
    letter-spacing: 2px !important;
}

/* Author/category section - consistent 10px top margin */
.opportunity-feed .wp-block-group .wp-block-group:has(.wp-block-post-author-name) {
    background: none !important;
    box-shadow: none !important;
    border: none !important;
    padding: 0 !important;
    margin-top: 10px !important;
    margin-bottom: 0 !important;
    margin-left: 0 !important;
    display: flex !important;
    flex-wrap: wrap !important;
    align-items: center !important;
    gap: 3px !important;
}

/* Author name font */
.opportunity-feed .wp-block-group .wp-block-post-author-name,
.opportunity-feed .wp-block-group .wp-block-post-author-name a {
    font-size: 1.25rem !important;
}

/* Category font */
.opportunity-feed .wp-block-group .taxonomy-category,
.opportunity-feed .wp-block-group .taxonomy-category a {
    font-size: 1.25rem !important;
}

/* "by" and "in" text */
.opportunity-feed .wp-block-group .wp-block-group p {
    font-size: 1.25rem !important;
    margin: 0 !important;
}

/* Remove extra margins */
.opportunity-feed .wp-block-group .wp-block-group:has(.wp-block-post-author-name) > * {
    margin: 0 !important;
    padding: 0 !important;
}

/* ========== EVENTS - Red ========== */
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) {
    background-color: #38001d !important;
}
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-post-title {
    color: #f24131 !important;
    border-bottom: 2px solid #f24131 !important;
}
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-post-date,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-post-date a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-post-author-name,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-post-author-name a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .taxonomy-category,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .taxonomy-category a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="events"]) .wp-block-group p {
    color: #f24131 !important;
}

/* ========== INTERNSHIPS - Green/Yellow ========== */
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) {
    background-color: #233935 !important;
}
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-post-title {
    color: #f3bd48 !important;
    border-bottom: 2px solid #f3bd48 !important;
}
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-post-date,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-post-date a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-post-author-name,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-post-author-name a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .taxonomy-category,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .taxonomy-category a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="internships"]) .wp-block-group p {
    color: #f3bd48 !important;
}

/* ========== JOB OPPORTUNITIES - Blue/Cyan ========== */
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) {
    background-color: #0e3240 !important;
}
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-post-title {
    color: #05daf2 !important;
    border-bottom: 2px solid #05daf2 !important;
}
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-post-date,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-post-date a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-post-author-name,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-post-author-name a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .taxonomy-category,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .taxonomy-category a,
.opportunity-feed .wp-block-group:has(.taxonomy-category a[href*="job-opportunities"]) .wp-block-group p {
    color: #05daf2 !important;
}

/* Excerpt text stays white for all */
.opportunity-feed .wp-block-group .wp-block-post-excerpt p {
    color: #ffffff !important;
}

/* Responsive - stack on mobile */
@media (max-width: 768px) {
    .opportunity-feed {
        padding: 40px 15px !important;
    }
    
    .opportunity-feed .wp-block-group {
        padding: 25px 30px !important;
    }
    
    .opportunity-feed .wp-block-group .wp-block-post-featured-image {
        float: none !important;
        margin: 0 auto 20px auto !important;
        width: 100% !important;
        max-width: 100% !important;
        text-align: center !important;
    }
    
    .opportunity-feed .wp-block-group .wp-block-post-title {
        font-size: 2rem !important;
    }
    
    .opportunity-feed .wp-block-group .wp-block-post-excerpt p {
        font-size: 1.2rem !important;
    }
}]]></wp:meta_value>
