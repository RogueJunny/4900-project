/* contact us form - professional clean design */

/* Main container */
.contact-us-form {
    max-width: 1200px;
    margin: 50px auto;
    position: relative;
    width: 100%;
}

/* Form background - clean white with subtle shadow */
.contact-us-form form,
.contact-us-form .wpcf7-form {
    background: #ffffff !important;
    padding: 60px 80px 40px 80px;
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    width: 100%;
    box-sizing: border-box;
    border: 1px solid #f0f0f0;
}

/* Grid layout for form fields */
.contact-us-form .wpcf7-form {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    margin-bottom: 0;
}

/* Name field */
.contact-us-form .wpcf7-form p:has([name="your-name"]) {
    grid-column: span 1;
    margin: 0;
}

/* Email field */
.contact-us-form .wpcf7-form p:has([name="your-email"]) {
    grid-column: span 1;
    margin: 0;
}

/* Subject field - full width */
.contact-us-form .wpcf7-form p:has([name="your-subject"]) {
    grid-column: span 2;
    margin: 0;
}

/* Message field - full width */
.contact-us-form .wpcf7-form p:has([name="your-message"]) {
    grid-column: span 2;
    margin: 0;
}

/* File upload - full width */
.contact-us-form .wpcf7-form p:has([type="file"]) {
    grid-column: span 2;
    margin: 0;
}

/* Submit button - full width */
.contact-us-form .wpcf7-form p:has([type="submit"]) {
    grid-column: span 2;
    margin: 10px 0 0 0;
}

/* Privacy text - full width */
.contact-us-form .wpcf7-form p:last-child {
    grid-column: span 2;
    margin: 20px 0 0 0 !important;
    padding: 20px 0 0 0;
    border-top: 1px solid #e5e7eb;
    color: #6b7280 !important;
    font-size: 14px;
    text-align: left;
    line-height: 1.6;
}

/* Privacy link */
.contact-us-form form p:last-child a,
.contact-us-form .wpcf7-form p:last-child a {
    color: #2563eb !important;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
}

.contact-us-form form p:last-child a:hover {
    color: #1d4ed8 !important;
    text-decoration: underline;
}

/* Form labels - professional dark gray */
.contact-us-form label {
    display: block;
    margin-bottom: 8px;
    color: #1f2937 !important;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
}

/* DIRECT LABEL TEXT REPLACEMENT */
.contact-us-form label:has([name="your-name"]) {
    color: transparent !important;
    position: relative;
    display: block;
}
.contact-us-form label:has([name="your-name"])::before {
    content: "Name";
    position: absolute;
    left: 0;
    top: 0;
    color: #1f2937;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
}

.contact-us-form label:has([name="your-email"]) {
    color: transparent !important;
    position: relative;
    display: block;
}
.contact-us-form label:has([name="your-email"])::before {
    content: "Email";
    position: absolute;
    left: 0;
    top: 0;
    color: #1f2937;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
}

.contact-us-form label:has([name="your-message"]) {
    color: transparent !important;
    position: relative;
    display: block;
}
.contact-us-form label:has([name="your-message"])::before {
    content: "Message (optional)";
    position: absolute;
    left: 0;
    top: 0;
    color: #1f2937;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.3px;
    text-transform: uppercase;
}

/* Input fields - clean modern design */
.contact-us-form input[type="text"],
.contact-us-form input[type="email"],
.contact-us-form input[type="tel"],
.contact-us-form textarea {
    width: 100% !important;
    padding: 14px 18px !important;
    margin-bottom: 0 !important;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    font-size: 16px;
    transition: all 0.2s ease;
    box-sizing: border-box;
    display: block !important;
    background: #f9fafb !important;
    color: #1f2937;
    font-family: inherit;
}

/* Textarea specific */
.contact-us-form textarea {
    min-height: 120px;
    resize: vertical;
}

/* File input - modern style */
.contact-us-form input[type="file"] {
    width: 100% !important;
    padding: 12px 18px !important;
    margin-bottom: 0 !important;
    border: 2px dashed #d1d5db;
    border-radius: 12px;
    font-size: 15px;
    transition: all 0.2s ease;
    box-sizing: border-box;
    display: block !important;
    cursor: pointer;
    background: #f9fafb !important;
    color: #4b5563;
}

/* File input label */
.contact-us-form label:has(+ input[type="file"]) {
    margin-bottom: 8px;
}

/* File input hover effect */
.contact-us-form input[type="file"]:hover {
    border-color: #2563eb;
    background: #f3f4f6 !important;
}

/* Placeholder text */
.contact-us-form input::placeholder,
.contact-us-form textarea::placeholder {
    color: #9ca3af;
    opacity: 1;
}

/* Focus states */
.contact-us-form input[type="text"]:focus,
.contact-us-form input[type="email"]:focus,
.contact-us-form input[type="tel"]:focus,
.contact-us-form textarea:focus,
.contact-us-form input[type="file"]:focus {
    border-color: #2563eb !important;
    background: #ffffff !important;
    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    outline: none;
}

/* Submit button - professional blue gradient */
.contact-us-form input[type="submit"] {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
    color: white;
    padding: 16px 32px;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
    letter-spacing: 0.5px;
    margin: 0;
    text-transform: uppercase;
}

.contact-us-form input[type="submit"]:hover {
    background: linear-gradient(135deg, #1d4ed8 0%, #1e3a8a 100%);
    transform: translateY(-1px);
    box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.3);
}

.contact-us-form input[type="submit"]:active {
    transform: translateY(0);
}

/* Validation messages */
.contact-us-form .wpcf7-not-valid-tip {
    color: #dc2626;
    font-size: 13px;
    margin-top: 6px;
    margin-bottom: 0;
    display: block;
    font-weight: 500;
}

/* Error state for inputs */
.contact-us-form .wpcf7-not-valid {
    border-color: #dc2626 !important;
    background: #fef2f2 !important;
}

/* Success message */
.contact-us-form .wpcf7-mail-sent-ok {
    background: #10b981;
    color: white;
    padding: 16px 20px;
    border-radius: 12px;
    margin: 20px 0 0 0;
    font-size: 15px;
    text-align: center;
    font-weight: 500;
    grid-column: span 2;
}

/* Response area */
.contact-us-form .wpcf7-response-output {
    margin: 20px 0 0 0 !important;
    padding: 16px !important;
    border-radius: 12px;
    border: none !important;
    font-size: 15px;
    grid-column: span 2;
    font-weight: 500;
}

/* Hide line breaks */
.contact-us-form br {
    display: none;
}

/* Mobile */
@media (max-width: 768px) {
    .contact-us-form {
        max-width: 95%;
        margin: 30px auto;
    }
    
    .contact-us-form .wpcf7-form {
        grid-template-columns: 1fr;
        gap: 24px;
    }
    
    .contact-us-form .wpcf7-form p {
        grid-column: span 1 !important;
    }
    
    .contact-us-form form,
    .contact-us-form .wpcf7-form {
        padding: 30px 20px 30px 20px;
    }
    
    .contact-us-form input[type="text"],
    .contact-us-form input[type="email"],
    .contact-us-form input[type="tel"],
    .contact-us-form textarea {
        padding: 12px 16px !important;
    }
    
    .contact-us-form input[type="file"] {
        padding: 10px 16px !important;
        font-size: 14px;
    }
    
    .contact-us-form input[type="submit"] {
        padding: 14px 24px;
        font-size: 15px;
    }
    
    .contact-us-form .wpcf7-form p:last-child {
        font-size: 12px;
        text-align: center;
    }
}

/* Large screens */
@media (min-width: 1200px) {
    .contact-us-form {
        max-width: 1400px;
    }
    
    .contact-us-form form,
    .contact-us-form .wpcf7-form {
        padding: 70px 100px 50px 100px;
    }
    
    .contact-us-form input[type="file"] {
        padding: 14px 20px !important;
    }
}


















































