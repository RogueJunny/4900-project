    background-repeat: no-repeat !important;
    border: none !important;
    outline: none !important;
    padding: 0 !important;
    margin: 0 !important;
}

/* Remove any styles from the previous .custom-image that might affect children */
.custom-image * {
    /* Reset any inherited styles */
