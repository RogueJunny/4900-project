<!-- /wp:list -->

<!-- wp:paragraph {"align":"center","className":"list-bug-fix-padding-title ","style":{"typography":{"fontSize":"2.5rem"}},"fontFamily":"franklin-gothic-atf"} -->
<p class="has-text-align-center list-bug-fix-padding-title has-franklin-gothic-atf-font-family" style="font-size:2.5rem">Checklist</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"align":"center","style":{"typography":{"fontSize":"1.75rem"},"spacing":{"padding":{"top":"var:preset|spacing|20","bottom":"var:preset|spacing|20"}}},"fontFamily":"system-sans-serif"} -->
<p class="has-text-align-center has-system-sans-serif-font-family" style="padding-top:var(--wp--preset--spacing--20);padding-bottom:var(--wp--preset--spacing--20);font-size:1.75rem">Your career journey starts with enrollment, but the steps you take afterward are what truly shape your success. The CIS Connect team are committed to providing every student with the information and resources to confidently navigate the road from orientation to graduation and beyond into your first professional role. Watch some tips to get you started.</p>
<!-- /wp:paragraph -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"mediaId":2695,"mediaLink":"https://testingcis.commons.gc.cuny.edu/resume-templates/xrddaemgij3e0o668j7914347376183964139t23071817/","mediaType":"image","className":"cl-media-text-right "} -->
