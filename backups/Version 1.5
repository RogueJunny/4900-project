<!-- wp:column {"style":{"spacing":{"padding":{"top":"var:preset|spacing|10","bottom":"var:preset|spacing|10","left":"var:preset|spacing|10","right":"var:preset|spacing|10"}}}} -->
<div class="wp-block-column" style="padding-top:var(--wp--preset--spacing--10);padding-right:var(--wp--preset--spacing--10);padding-bottom:var(--wp--preset--spacing--10);padding-left:var(--wp--preset--spacing--10)"><!-- wp:list {"style":{"typography":{"fontSize":"1.5rem"},"spacing":{"padding":{"right":"0","left":"0"}}},"fontFamily":"system-sans-serif"} -->
<ul style="padding-right:0;padding-left:0;font-size:1.5rem" class="wp-block-list has-system-sans-serif-font-family"><!-- wp:list-item -->
<li>Company open houses or info sessions</li>
<!-- /wp:list-item -->

<!-- wp:list-item -->
<li>LinkedIn Local events</li>
<!-- /wp:list-item -->

<!-- wp:list-item -->
<li>Chamber of commerce gatherings</li>
