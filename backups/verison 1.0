<!-- /wp:spacer -->

<!-- wp:group {"metadata":{"name":"Off-Campus"},"align":"wide","style":{"color":{"text":"#011d49","background":"#a3c9ff57"},"elements":{"link":{"color":{"text":"#011d49"}}}},"layout":{"type":"constrained"}} -->
<div class="wp-block-group alignwide has-text-color has-background has-link-color" style="color:#011d49;background-color:#a3c9ff57"><!-- wp:media-text {"align":"","mediaId":283,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/admin-ajax/","mediaType":"image","mediaWidth":25,"verticalAlignment":"bottom"} -->
<div class="wp-block-media-text is-stacked-on-mobile is-vertically-aligned-bottom" style="grid-template-columns:25% auto"><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/10/admin-ajax.jpeg" alt="Brooklyn College Tower and Skyline" class="wp-image-283 size-full" /></figure><div class="wp-block-media-text__content"><!-- wp:heading -->
<h2 class="wp-block-heading"><strong>Off-Campus Resources &amp; Opportunities</strong></h2>
<!-- /wp:heading --></div></div>
<!-- /wp:media-text -->

<!-- wp:spacer {"height":"40px"} -->
<div style="height:40px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:paragraph {"align":"center","fontSize":"large"} -->
<p class="has-text-align-center has-large-font-size">These are some wonderful off-campus (including online) resources and opportunities that shouldn't be missed-out on!</p>
<!-- /wp:paragraph -->

<!-- wp:spacer {"height":"40px"} -->
<div style="height:40px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:group {"fontSize":"large","layout":{"type":"constrained"}} -->
<div class="wp-block-group has-large-font-size"><!-- wp:details {"align":"wide"} -->
<details class="wp-block-details alignwide"><summary>NYC DCAS Summer Internship Program</summary><!-- wp:paragraph {"align":"left"} -->
<p class="has-text-align-left"><a href="https://www.nyc.gov/site/dcas/employment/summer-internship-program-oti.page">Check back to see if there are open positions!</a></p>
<!-- /wp:paragraph --></details>
<!-- /wp:details -->

<!-- wp:separator {"className":"is-style-dots"} -->
<hr class="wp-block-separator has-alpha-channel-opacity is-style-dots" />
<!-- /wp:separator -->

<!-- wp:details {"align":"wide"} -->
<details class="wp-block-details alignwide"><summary>Teach Yourself Computer Science (Website)</summary><!-- wp:paragraph -->
<p><a href="https://teachyourselfcs.com/">Click here to learn!</a></p>
<!-- /wp:paragraph --></details>
<!-- /wp:details -->

<!-- wp:separator {"className":"is-style-dots"} -->
<hr class="wp-block-separator has-alpha-channel-opacity is-style-dots" />
