					<item>
		<title><![CDATA[About]]></title>
		<link>https://cisbridge.commons.gc.cuny.edu/about/</link>
		<pubDate>Thu, 30 Oct 2025 01:25:28 +0000</pubDate>
		<dc:creator><![CDATA[suraiyapm]]></dc:creator>
		<guid isPermaLink="false">https://cisbridge.commons.gc.cuny.edu/?page_id=275</guid>
		<description></description>
		<content:encoded><![CDATA[<!-- wp:image {"id":977,"width":"506px","height":"auto","sizeSlug":"large","linkDestination":"none","align":"center","className":"is-style-default"} -->
<figure class="wp-block-image aligncenter size-large is-resized is-style-default"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/12/Brooklyn_College_Logo.svg_-1024x455.png" alt="Brooklyn College CUNY Banner" class="wp-image-977" style="width:506px;height:auto" /></figure>
<!-- /wp:image -->

<!-- wp:spacer {"height":"54px"} -->
<div style="height:54px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:paragraph {"align":"center","fontSize":"large"} -->
<p class="has-text-align-center has-large-font-size">This website serves as a bridge for students to the professional industry.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"align":"center","fontSize":"regular"} -->
<p class="has-text-align-center has-regular-font-size"><br>A concept thought up by Academic Program Specialist Fendja Larivaux, and to be realized beginning in Fall 2025,  Brooklyn College CIS Connect is a place to make resources, opportunities, and information as easily accessible as possible for students in computer and information science.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"align":"center","fontSize":"regular"} -->
<p class="has-text-align-center has-regular-font-size">Many university sources of information fall out of being kept regularly up to date, and can often be scattered across several websites that students may never even be aware of. This website strives to make everything as easy to find as possible, hopefully leaving students with an increased awareness of opportunities they can take advantage of! Whether it's study materials to complement your academic path, or resources to ease your transition into the industry, Brooklyn College CIS Connect is here to support you!</p>
<!-- /wp:paragraph -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:site-logo {"width":248,"shouldSyncIcon":false,"align":"center","className":"is-style-rounded"} /-->

<!-- wp:heading {"textAlign":"center","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<h2 class="wp-block-heading has-text-align-center has-text-color has-link-color" style="color:#011d49">Meet the Faculty!</h2>
<!-- /wp:heading -->

<!-- wp:group {"layout":{"type":"constrained"}} -->
<div class="wp-block-group"><!-- wp:paragraph {"align":"center"} -->
<p class="has-text-align-center">Need more faculty contact information?</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"align":"center","fontSize":"regular"} -->
<p class="has-text-align-center has-regular-font-size"><a href="https://websql.brooklyn.cuny.edu/directory/search.jsp?department=109&amp;mode=staffList">Find more information in the directory here!</a></p>
<!-- /wp:paragraph --></div>
<!-- /wp:group -->

<!-- wp:columns -->
<div class="wp-block-columns"><!-- wp:column {"width":"100%"} -->
<div class="wp-block-column" style="flex-basis:100%"><!-- wp:group {"layout":{"type":"constrained"}} -->
<div class="wp-block-group"><!-- wp:columns {"verticalAlignment":"center"} -->
<div class="wp-block-columns are-vertically-aligned-center"><!-- wp:column {"verticalAlignment":"center","width":"100%"} -->
<div class="wp-block-column is-vertically-aligned-center" style="flex-basis:100%"></div>
<!-- /wp:column --></div>
<!-- /wp:columns --></div>
<!-- /wp:group --></div>
<!-- /wp:column --></div>
<!-- /wp:columns -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaPosition":"right","mediaId":655,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/fendja-larivaux/","mediaType":"image","mediaWidth":36,"mediaSizeSlug":"full","verticalAlignment":"center","className":"is-style-default .hover-shading","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide has-media-on-the-right is-stacked-on-mobile is-vertically-aligned-center is-style-default .hover-shading has-text-color has-link-color" style="color:#011d49;grid-template-columns:auto 36%"><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Fendja Larivaux</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Academic Program Specialist</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>2114 Ingersoll Hall | 718.951.5000x2045 | fendja.larivaux@brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}},"fontSize":"regular"} -->
<p class="has-text-color has-link-color has-regular-font-size" style="color:#011d49">Fendja Larivaux is an Academic Program Specialist, and the mind behind Brooklyn College CIS Connect. She is an Experienced Technical Program Manager with a demonstrated history of working in the higher education industry, and a Master's Degree focused in Higher Education/Higher Education Administration.</p>
<!-- /wp:paragraph -->

<!-- wp:details -->
<details class="wp-block-details"><summary>Center for an Urban Future Article</summary><!-- wp:paragraph {"placeholder":"Type / to add a hidden block"} -->
<p><a href="https://nycfuture.org/research/doubling-down-on-cuny-2x-tech">Boosting Tech Career Success for CUNY Students: Doubling Down on CUNY 2X Tech (featuring quotes from F. Larivaux)</a></p>
<!-- /wp:paragraph --></details>
<!-- /wp:details --></div><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/Fendja-Larivaux.jpeg" alt="Fendja Larivaux, Academic Program Specialist and the mind behind CIS Connect!" class="wp-image-655 size-full" /></figure></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaId":665,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/hui-chen/","mediaType":"image","mediaWidth":36,"verticalAlignment":"center","className":".hover-shading","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide is-stacked-on-mobile is-vertically-aligned-center .hover-shading has-text-color has-link-color" style="color:#011d49;grid-template-columns:36% auto"><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/HUI-CHEN.jpg" alt="Hui Chen - Faculty" class="wp-image-665 size-full" /></figure><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Hui Chen</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Associate Professor</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>1432 Ingersoll Hall | 718.951.5000x2055 | chen@sci.brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Hui Chen is an Associate Professor in the Department of Computer &amp; Information Science at Brooklyn College, and a member of the doctoral faculty in the CUNY Computer Science Ph.D. program. His current research focuses on the modeling and analytics of computer systems, networks, and software.</p>
<!-- /wp:paragraph --></div></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaPosition":"right","mediaId":689,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/katherine-chuang/","mediaType":"image","mediaWidth":36,"mediaSizeSlug":"full","verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide has-media-on-the-right is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:auto 36%"><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49">Katherine Chuang</h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Lecturer/Doctoral Lecturer</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>1212 Ingersoll Hall | 718.951.5000x2069 | chuang@sci.brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}},"fontSize":"regular"} -->
<p class="has-text-color has-link-color has-regular-font-size" style="color:#011d49">Katherine Chuang is a Senior Doctoral Lecturer of Computer Science at Brooklyn College. Dr. Chuang joined the faculty in the Department of Computer and Information Science in Fall 2019 after teaching as an adjunct. She teaches several of the core undergraduate courses in the department with developing curricula alongside including a practical perspective of technical skill assessment to the classroom.</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}},"fontSize":"regular"} -->
<p class="has-text-color has-link-color has-regular-font-size" style="color:#011d49">Prior to joining, she earned her doctorate specializing in developing analytical and empirical research techniques of studying social media design and spent many years of practice in the tech industry. Her primary focus these days contributes to the symbiotic relationship between academia and the tech industry. She currently serves as the Associate Director of the Roberta S. Matthews Center for Teaching and Learning.</p>
<!-- /wp:paragraph --></div><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/Katherine-Chuang.jpg" alt="Katherine Chuang - Faculty" class="wp-image-689 size-full" /></figure></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaId":695,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/panneer-selvam-santhalingam/","mediaType":"image","mediaWidth":36,"verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:36% auto"><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/Panneer-Selvam-Santhalingam.jpg" alt="Panneer Selvam Santhalingam - Faculty" class="wp-image-695 size-full" /></figure><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Panneer Selvam Santhalingam</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Instructor</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>2232 Ingersoll Hall | 718.951.5000x2053 | ps.santhalingam@brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Panneer Selvam Santhalingam is an Assistant Professor at the Department of Computer and Information Science at Brooklyn College. His Research work focuses on enabling alternative sensing modalities that are low-power, cheap, and ubiquitous. He is interested in developing solutions that address the accessibility challenges of deaf and hard-of-hearing people. He also collaborates on wireless communications projects on ray propagation modeling and next-generation wireless networks.</p>
<!-- /wp:paragraph --></div></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaPosition":"right","mediaId":701,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/priyanka-samanta/","mediaType":"image","mediaWidth":36,"mediaSizeSlug":"full","verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide has-media-on-the-right is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:auto 36%"><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Priyanka Samanta</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Lecturer</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>samanta@brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}},"fontSize":"regular"} -->
<p class="has-text-color has-link-color has-regular-font-size" style="color:#011d49">Priyanka Samanta is a lecturer in Computer Science at Brooklyn College. She is dedicated to fostering a deep understanding of computing principles through engaging and practical coursework.</p>
<!-- /wp:paragraph --></div><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/Priyanka-Samanta.jpg" alt="Priyanka Samanta - Faculty" class="wp-image-701 size-full" /></figure></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaId":669,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/ira-rudowsky/","mediaType":"image","mediaWidth":36,"mediaSizeSlug":"full","verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:36% auto"><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/IRA-RUDOWSKY.jpg" alt="Ira Rudowsky - Faculty" class="wp-image-669 size-full" /></figure><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Ira Rudowsky</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Professor</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>1417 Ingersoll Hall | 718.951.5000x2062 | rudowsky@brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}},"fontSize":"regular"} -->
<p class="has-text-color has-link-color has-regular-font-size" style="color:#011d49">Ira Rudowsky has been a professor in the Department of Computer and Information Science since September 2001.</p>
<!-- /wp:paragraph --></div></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaPosition":"right","mediaId":711,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/rebecca-rivka-levitan/","mediaType":"image","mediaWidth":36,"mediaSizeSlug":"full","verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide has-media-on-the-right is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:auto 36%"><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Rebecca Levitan</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Professor</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>3114 Ingersoll Hall | 718.951.5000x3997 | rlevitan@brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}},"fontSize":"regular"} -->
<p class="has-text-color has-link-color has-regular-font-size" style="color:#011d49">Rivka Levitan is a professor at Brooklyn College and the CUNY Graduate Center. Her research involves spoken language processing, discourse, and human computer interaction. Previously, Rivka was a post-doc in the Speech Lab at Columbia University and received a PhD in Computer Science from Columbia University.</p>
<!-- /wp:paragraph --></div><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/Rebecca-Rivka-Levitan.jpg" alt="Rebecca Rivka Levitan - Faculty" class="wp-image-711 size-full" /></figure></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaId":671,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/james-l-cox/","mediaType":"image","mediaWidth":36,"verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:36% auto"><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/JAMES-L.-COX.jpg" alt="James L. Cox - Faculty" class="wp-image-671 size-full" /></figure><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>James L. Cox</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Associate Professor</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>2112c Ingersoll Hall | 718.951.5000x2047 | jcox@brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">James Cox was awarded a fellowship by NYU Courant Institute in 1983 and completed a Ph.D. in 1988, in robotics algorithms. Since then, his research has focused on problems in computer science having a significant mathematical component.</p>
<!-- /wp:paragraph --></div></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaPosition":"right","mediaId":721,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/theodore-raphan/","mediaType":"image","mediaWidth":36,"verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide has-media-on-the-right is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:auto 36%"><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Theodore Raphan</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Professor</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>541 Ingersoll Hall | 718.951.4193 | raphan@nsi.brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Theodore Raphan was a postdoctoral fellow in neurophysiology at Mt. Sinai School of Medicine and was appointed assistant professor of neurology in 1979. Since coming to Brooklyn College in 1982, he has been associate professor, professor and Broeklundian Professor of Computer and Information Science. He was appointed Distinguished Professor in 1994. He directs the Institute of Neural and Intelligent Systems at Brooklyn College and does research in several areas in STEM.</p>
<!-- /wp:paragraph -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer --></div><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/Theodore-Raphan.jpg" alt="Theodore Raphan - Faculty" class="wp-image-721 size-full" /></figure></div>
<!-- /wp:media-text -->

<!-- wp:spacer -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:media-text {"align":"wide","mediaId":731,"mediaLink":"https://cisbridge.commons.gc.cuny.edu/about/yongqing-xiang/","mediaType":"image","mediaWidth":36,"mediaSizeSlug":"full","verticalAlignment":"center","className":"is-style-default","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-media-text alignwide is-stacked-on-mobile is-vertically-aligned-center is-style-default has-text-color has-link-color" style="color:#011d49;grid-template-columns:36% auto"><figure class="wp-block-media-text__media"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/11/Yongqing-Xiang.jpg" alt="Yongqing Xiang - Faculty" class="wp-image-731 size-full" /></figure><div class="wp-block-media-text__content"><!-- wp:heading {"style":{"color":{"text":"#011d49"}}} -->
<h2 class="wp-block-heading has-text-color" style="color:#011d49"><strong>Yongqing Xiang</strong></h2>
<!-- /wp:heading -->

<!-- wp:paragraph {"fontSize":"regular"} -->
<p class="has-regular-font-size">Lecturer/Doctoral Lecturer</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"fontSize":"small"} -->
<p class="has-small-font-size"><em>2156a Ingersoll Hall | 718.951.5000x1517 | yxiang@brooklyn.cuny.edu</em></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}},"fontSize":"regular"} -->
<p class="has-text-color has-link-color has-regular-font-size" style="color:#011d49">[Couldn't find a description. For the ones without a description on the site itself, I checked LinkedIn.]</p>
<!-- /wp:paragraph --></div></div>
<!-- /wp:media-text -->

<!-- wp:paragraph -->
<p></p>
<!-- /wp:paragraph -->]]></content:encoded>
