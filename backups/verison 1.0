<!-- /wp:spacer -->

<!-- wp:paragraph {"style":{"color":{"text":"#011d49"},"typography":{"fontSize":"17px"}}} -->
<p class="has-text-color" style="color:#011d49;font-size:17px">Check out the Girls Who Code Brooklyn College Instagram page! This photo is from a recent career panel event.</p>
