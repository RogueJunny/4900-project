					<item>
		<title><![CDATA[Media Gallery]]></title>
		<link>https://cisbridge.commons.gc.cuny.edu/media-gallery/</link>
		<pubDate>Thu, 30 Oct 2025 01:38:09 +0000</pubDate>
		<dc:creator><![CDATA[suraiyapm]]></dc:creator>
		<guid isPermaLink="false">https://cisbridge.commons.gc.cuny.edu/?page_id=291</guid>
		<description></description>
		<content:encoded><![CDATA[<!-- wp:group {"tagName":"section","metadata":{"categories":["gallery"],"patternName":"core/three-columns-with-images-and-text","name":"Three columns with images and text"},"align":"full","style":{"spacing":{"padding":{"top":"6vw","bottom":"6vw","left":"6vw","right":"6vw"}}},"layout":{"type":"default"}} -->
<section class="wp-block-group alignfull" style="padding-top:6vw;padding-right:6vw;padding-bottom:6vw;padding-left:6vw"><!-- wp:spacer {"height":"1vw"} -->
<div style="height:1vw" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","style":{"spacing":{"blockGap":{"top":"3vw","left":"3vw"}},"color":{"background":"#a307431f","text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-columns alignwide has-text-color has-background has-link-color" style="color:#011d49;background-color:#a307431f"><!-- wp:column {"width":"33.38%","style":{"color":{"text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-column has-text-color has-link-color" style="color:#011d49;flex-basis:33.38%"><!-- wp:paragraph -->
<p></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph -->
<p></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"typography":{"fontSize":"17px"}}} -->
<p style="font-size:17px">At Brooklyn College, career and opportunity-related events take place regularly, alongside club events and meetings!</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph -->
<p></p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"style":{"typography":{"fontSize":"17px"}}} -->
<p style="font-size:17px">This page will showcase some media galleries from recent on-campus events related to CIS.</p>
<!-- /wp:paragraph --></div>
<!-- /wp:column -->

<!-- wp:column {"width":"33%"} -->
<div class="wp-block-column" style="flex-basis:33%"><!-- wp:spacer {"height":"2vw"} -->
<div style="height:2vw" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:image {"id":281,"sizeSlug":"full","linkDestination":"none","className":"is-style-default"} -->
<figure class="wp-block-image size-full is-style-default"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/10/bc_logo.png" alt="Brooklyn College Logo Line art" class="wp-image-281" /></figure>
<!-- /wp:image --></div>
<!-- /wp:column -->

<!-- wp:column {"width":"33.62%"} -->
<div class="wp-block-column" style="flex-basis:33.62%"><!-- wp:image {"id":293,"width":"179px","height":"auto","sizeSlug":"full","linkDestination":"none"} -->
<figure class="wp-block-image size-full is-resized"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/10/bccs-club-logo.png" alt="Brooklyn College Computer Science Club Logo art" class="wp-image-293" style="width:179px;height:auto" /></figure>
<!-- /wp:image -->

<!-- wp:image {"id":1015,"aspectRatio":"1","scale":"cover","sizeSlug":"large","linkDestination":"none","className":"is-style-default"} -->
<figure class="wp-block-image size-large is-style-default"><img src="https://s3.amazonaws.com/files.commons.gc.cuny.edu/wp-content/blogs.dir/43977/files/2025/12/brighter-white-logo-1024x1024.png" alt="Current Active BC CIS Conn Logo - Suraiya P. Mark" class="wp-image-1015" style="aspect-ratio:1;object-fit:cover" /></figure>
<!-- /wp:image --></div>
<!-- /wp:column --></div>
<!-- /wp:columns -->

<!-- wp:spacer {"style":{"layout":[]}} -->
<div style="height:100px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

<!-- wp:columns {"align":"wide","style":{"spacing":{"blockGap":{"left":"3vw"}},"color":{"background":"#a3c9ff61","text":"#011d49"},"elements":{"link":{"color":{"text":"#011d49"}}}}} -->
<div class="wp-block-columns alignwide has-text-color has-background has-link-color" style="color:#011d49;background-color:#a3c9ff61"><!-- wp:column {"width":"69%"} -->
<div class="wp-block-column" style="flex-basis:69%"><!-- wp:html -->
