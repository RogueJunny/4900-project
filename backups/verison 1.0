<div class="wp-block-group"><!-- wp:site-title {"textAlign":"left","style":{"elements":{"link":{"color":{"text":"var:preset|color|background"}}},"layout":{"selfStretch":"fit","flexSize":null}},"textColor":"white"} /--></div>
