<details class="wp-block-details alignwide" style="font-size:1.5rem"><summary><strong>Red Flags to Watch For</strong></summary><!-- wp:list {"style":{"spacing":{"margin":{"right":"var:preset|spacing|20","left":"var:preset|spacing|20"}}}} -->
<ul style="margin-right:var(--wp--preset--spacing--20);margin-left:var(--wp--preset--spacing--20)" class="wp-block-list"><!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
<li style="font-size:1.25rem">Interviewers who are vague about job duties.</li>
<!-- /wp:list-item -->

<!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
<li style="font-size:1.25rem">High turnover mentioned casually.</li>
<!-- /wp:list-item -->

<!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
<li style="font-size:1.25rem">Disrespectful treatment during the interview process.</li>
<!-- /wp:list-item -->

<!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
<li style="font-size:1.25rem">Pressure to accept immediately.</li>
<!-- /wp:list-item -->

<!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
<li style="font-size:1.25rem">Unwillingness to discuss salary or benefits.</li>
<!-- /wp:list-item -->

<!-- wp:list-item {"style":{"typography":{"fontSize":"1.25rem"}}} -->
