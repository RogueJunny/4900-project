		<wp:meta_value><![CDATA[/* Container for all three columns - full width */
.three-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr); /* 3 equal columns */
    width: 100vw !important;
    max-width: 100vw !important;
    margin-left: calc(-50vw + 50%) !important;
    margin-right: calc(-50vw + 50%) !important;
    gap: 20px !important; /* Space BETWEEN columns */
    padding-top: 15px !important;
    padding-right: 300px !important;
    padding-left: 300px !important;
}

/* Add padding to create space from edges */
.three-columns > * {
    background-color: #F7F4EB !important;
    padding: 40px 30px !important;
    margin: 20px !important;
    border-radius: 8px;
}

/* Responsive adjustments - only changes margins and layout for smaller screens */
@media (max-width: 1400px) {
    .three-columns {
        padding-right: 150px !important;
        padding-left: 150px !important;
    }
}

@media (max-width: 1200px) {
    .three-columns {
        padding-right: 80px !important;
        padding-left: 80px !important;
        gap: 15px !important;
    }
    
    .three-columns > * {
        padding: 30px 25px !important;
        margin: 15px !important;
    }
}

@media (max-width: 992px) {
    .three-columns {
        grid-template-columns: repeat(2, 1fr) !important; /* 2 columns on tablet */
        padding-right: 50px !important;
        padding-left: 50px !important;
        gap: 20px !important;
    }
    
    .three-columns > * {
        padding: 30px 25px !important;
        margin: 10px !important;
    }
}

@media (max-width: 768px) {
    .three-columns {
        grid-template-columns: 1fr !important; /* 1 column on mobile */
        padding-right: 20px !important;
        padding-left: 20px !important;
        gap: 20px !important;
    }
    
    .three-columns > * {
        padding: 25px 20px !important;
        margin: 5px !important;
    }
}






