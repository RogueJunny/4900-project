<!-- /wp:paragraph -->

<!-- wp:paragraph {"align":"center","style":{"typography":{"fontSize":"1.25rem"}},"fontFamily":"system-sans-serif"} -->
<p class="has-text-align-center has-system-sans-serif-font-family" style="font-size:1.25rem"><strong>Not the right fit? Check out the complete directory of Brooklyn College clubs.</strong></p>
<!-- /wp:paragraph -->

