/* Make the list block sticky with background image box */
.wp-block-list.sticky-jump-list {
    position: -webkit-sticky;
    position: sticky;
    top: 50px;
    float: right;
    right: 20px;
    max-width: 350px;
    width: 350px; /* Explicit width for Firefox */
    z-index: 999;
    list-style: none;
    margin: 0 20px 0 0;
    padding: 20px;
    background-image: url('https://i.imgur.com/2HWAQ4a.png');
    background-repeat: repeat;
    background-size: auto;
    background-position: center;
    border-radius: 4px;
    text-align: center;
    margin-top: 50px;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 
                0 8px 10px -6px rgba(0, 0, 0, 0.2),
                inset 0 -2px 5px rgba(0, 0, 0, 0.1),
                inset 0 2px 5px rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(243, 189, 72, 0.2);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    
    /* Remove any extra spacing */
    line-height: 1.2;
    
    /* Firefox-specific fixes */
    display: block; /* Ensure proper display */
    clear: both; /* Prevent float issues */
    box-sizing: border-box; /* Consistent box model */
}

/* TITLE */
.wp-block-list.sticky-jump-list::before {
    content: "On This Page";
    display: block;
    font-family: "Franklin Gothic ATF", "Franklin Gothic Medium", "Franklin Gothic", Arial, sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: #F3BD48;
    text-align: center;
    margin-bottom: 16px;
    padding-bottom: 10px;
    width: 85%;
    margin-left: auto;
    margin-right: auto;
    border-bottom: 3px solid #F3BD48;
}

/* Hover effect for box */
.wp-block-list.sticky-jump-list:hover {
    box-shadow: 0 20px 30px -8px rgba(0, 0, 0, 0.4), 
                0 10px 15px -6px rgba(0, 0, 0, 0.3),
                inset 0 -3px 8px rgba(0, 0, 0, 0.15),
                inset 0 3px 8px rgba(255, 255, 255, 0.4);
    transform: translateY(-2px);
}

/* Glow layer */
.wp-block-list.sticky-jump-list::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 4px;
    box-shadow: inset 0 0 20px rgba(243, 189, 72, 0.1);
    pointer-events: none;
    z-index: 1;
}

/* LINKS */
.wp-block-list.sticky-jump-list a {
    display: block;
    padding: 6px 8px;
    text-decoration: none;
    color: #F3BD48;
    font-size: 1.25rem;
    line-height: 1.2;
    text-align: center;
    transition: color 0.2s ease,
                transform 0.2s ease,
                text-shadow 0.2s ease;
    font-weight: 500;
    opacity: 0.95;
    border-right: none;
    margin-bottom: 2px;
    text-shadow: 0 1px 1px rgba(0,0,0,0.15);
    outline: none;
}

/* Accessibility focus */
.wp-block-list.sticky-jump-list a:focus-visible {
    outline: 2px solid #F3BD48;
    outline-offset: 2px;
    border-radius: 2px;
}

/* List items */
.wp-block-list.sticky-jump-list li {
    text-align: center;
    width: 100%;
    overflow: visible;
    margin: 0;
    padding: 0;
    list-style: none;
    line-height: 1.2;
    
    /* Remove any default list spacing */
    margin-block-start: 0;
    margin-block-end: 0;
}

/* HOVER LINKS — slightly bigger */
.wp-block-list.sticky-jump-list a:hover {
    color: #FFD66B;
    transform: scale(1.06);
    text-shadow: 0 2px 3px rgba(0,0,0,0.25);
}

/* Active */
.wp-block-list.sticky-jump-list a:active {
    transform: scale(1.03);
}

/* Paragraphs */
.wp-block-list.sticky-jump-list p {
    margin: 0;
    padding: 0;
    text-align: center;
    
    /* Remove paragraph spacing */
    margin-block-start: 0;
    margin-block-end: 0;
}

/* Hide on mobile */
@media (max-width: 768px) {
    .wp-block-list.sticky-jump-list {
        display: none;
    }
}

/* Firefox-specific override using @supports */
@supports (-moz-appearance: none) {
    .wp-block-list.sticky-jump-list {
        /* Reset any problematic values for Firefox */
        margin-top: 50px !important;
        position: sticky !important;
        top: 50px !important;
        
        /* Force hardware acceleration */
        transform: translateZ(0);
        
        /* Ensure proper containment */
        contain: layout style paint;
    }
    
    /* Fix for Firefox float/sticky interaction */
    .wp-block-list.sticky-jump-list::before {
        width: 100%;
    }
}













