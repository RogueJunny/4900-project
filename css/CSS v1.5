/* post css */

/* Background for the Post Media section/container - RED only */
.post-media-section {
    background-image: url('https://i.imgur.com/uYl5x4N.png');
    background-size: cover;
    background-position: center;
    padding: 60px 0 60px 0; /* REMOVED horizontal padding - using post margins instead */
    border-radius: 0;
    box-sizing: border-box;
}

/* Background for individual posts - YELLOW only */
.post-media-section .post {
    background-image: url('https://i.imgur.com/MA5OWJa.png');
    background-size: cover;
    background-position: center;
    border-radius: 25px;
    padding: 20px 40px 20px 40px;
    margin-bottom: 30px;
    margin-left: auto !important;
    margin-right: auto !important;
    box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    transition: all 0.3s ease;
    border: 1px solid #e0e0e0;
    color: #1e1e1e;
    max-width: 1200px;
    width: 90% !important;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
}

/* ========== POST IMAGE SCALING - MAKE THEM SMALLER ========== */
/* Target all images inside posts */
.post-media-section .post img,
.post-media-section .post .wp-block-post-featured-image img,
.post-media-section .post .wp-block-image img,
.post-media-section .post figure img,
.post-media-section .post .entry-content img {
    max-width: 40% !important;
    height: auto !important;
    width: auto !important;
    border-radius: 12px !important;
    display: block !important;
    margin: 20px 0 !important;
    object-fit: cover !important;
}

/* Center images if they're alone, or align left with text wrap */
.post-media-section .post .wp-block-post-featured-image {
    text-align: left !important;
    margin: 0 !important;
}

/* For featured images specifically */
.post-media-section .post .wp-block-post-featured-image img {
    max-width: 35% !important;
    border-radius: 12px !important;
    margin: 15px 20px 15px 0 !important;
    float: left !important;
}

/* Clear float after images */
.post-media-section .post .entry-content::after {
    content: "" !important;
    display: table !important;
    clear: both !important;
}

/* Responsive - even smaller on mobile */
@media (max-width: 768px) {
    .post-media-section {
        padding: 40px 0 40px 0 !important;
    }
    
    .post-media-section .post img,
    .post-media-section .post .wp-block-post-featured-image img,
    .post-media-section .post .wp-block-image img,
    .post-media-section .post figure img,
    .post-media-section .post .entry-content img {
        max-width: 60% !important;
        float: none !important;
        margin: 15px auto !important;
        display: block !important;
    }
    
    .post-media-section .post .wp-block-post-featured-image img {
        float: none !important;
        margin: 15px auto !important;
    }
}

@media (max-width: 576px) {
    .post-media-section .post {
        width: 95% !important; /* Slightly wider on very small screens */
        padding: 15px 25px 15px 25px;
    }
    
    .post-media-section .post img,
    .post-media-section .post .wp-block-post-featured-image img,
    .post-media-section .post .wp-block-image img,
    .post-media-section .post figure img,
    .post-media-section .post .entry-content img {
        max-width: 80% !important;
    }
}

/* Make sure NO child elements have the same styles */
.post-media-section .post * {
    background: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    border: none !important;
}

/* Post title styling - only text styles */
.post-media-section .post h2, 
.post-media-section .post .entry-title {
    color: #882346 !important;
    border-bottom: 2px solid #882346 !important;
    padding-bottom: 10px;
    margin-bottom: 12px;
    margin-top: 0;
    background: none !important;
    width: 100% !important;
    max-width: 100% !important;
}

/* Meta styling - only text */
.post-media-section .post .entry-meta {
    color: #1e1e1e;
    margin-bottom: 12px;
    margin-top: 0;
    background: none !important;
    padding: 0 !important;
    width: 100% !important;
}

/* Content styling - make it stretch */
.post-media-section .post .entry-content,
.post-media-section .post p,
.post-media-section .post div {
    width: 100% !important;
    max-width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
}

/* Last paragraph in content - remove bottom margin */
.post-media-section .post .entry-content p:last-child {
    margin-bottom: 0 !important;
}

/* Hover effect - ONLY on the main post bubble - with DARKER shadow */
.post-media-section .post:hover {
    box-shadow: 0 15px 30px rgba(0,0,0,0.35);
    transform: translateY(-3px);
}

/* Ensure nothing inside changes on hover */
.post-media-section .post:hover * {
    transform: none !important;
    box-shadow: none !important;
}

/* =========================================
   FIX WORDPRESS ROW BLOCK META SPACING & AUTHOR NAME WRAPPING
========================================= */

/* Target the Row block - prevent author name wrapping */
.post-media-section .wp-block-group.is-layout-flex {
    justify-content: flex-start !important;
    gap: 6px !important;
    flex-wrap: wrap !important; /* Allow wrapping of the whole row if needed */
    align-items: center !important;
}

/* Prevent the author name block from breaking internally */
.post-media-section .wp-block-post-author-name {
    white-space: nowrap !important;
    display: inline-block !important;
}

/* Also prevent the link inside from wrapping */
.post-media-section .wp-block-post-author-name a {
    white-space: nowrap !important;
    display: inline-block !important;
}

/* Make all children inline-sized */
.post-media-section .wp-block-group.is-layout-flex > * {
    margin: 0 !important;
    padding: 0 !important;
    width: auto !important;
    max-width: none !important;
}

/* Ensure text flows naturally */
.post-media-section .wp-block-group.is-layout-flex p {
    margin: 0 !important;
}

/* Remove bottom margin from the last post */
.post-media-section .post:last-child {
    margin-bottom: 0 !important;
}

/* Ensure the last post's content doesn't create extra space */
.post-media-section .post:last-child .entry-content {
    margin-bottom: 0 !important;
}

/* =========================================
   TARGET ENTIRE POST GROUP - COLORS & FONT
   EXCERPT KEEPS ORIGINAL FONT
========================================= */

/* Target everything inside the post group */
.post-media-section .wp-block-group.post.is-layout-flow * {
    color: #882346 !important;
    font-family: "Franklin Gothic ATF", "Franklin Gothic", "Franklin Gothic Book", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
}

/* EXCEPTIONS - Elements that should keep original colors AND original font */

/* Keep post content paragraphs at original color (but use Franklin Gothic) */
.post-media-section .wp-block-group.post.is-layout-flow .entry-content p,
.post-media-section .wp-block-group.post.is-layout-flow .entry-content * {
    color: #1e1e1e !important;
    font-family: "Franklin Gothic ATF", "Franklin Gothic", "Franklin Gothic Book", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
}

/* Keep EXCERPT blocks at original color AND ORIGINAL FONT */
.post-media-section .wp-block-group.post.is-layout-flow .wp-block-post-excerpt,
.post-media-section .wp-block-group.post.is-layout-flow .wp-block-post-excerpt *,
.post-media-section .wp-block-group.post.is-layout-flow .wp-block-post-excerpt p,
.post-media-section .wp-block-group.post.is-layout-flow .entry-excerpt,
.post-media-section .wp-block-group.post.is-layout-flow .entry-excerpt * {
    color: #1e1e1e !important;
    font-family: inherit !important; /* This keeps the original theme font */
}

/* Keep post titles at their original color (but use Franklin Gothic) */
.post-media-section .wp-block-group.post.is-layout-flow h2,
.post-media-section .wp-block-group.post.is-layout-flow .entry-title {
    color: #882346 !important;
    border-bottom: 2px solid #882346 !important;
    font-family: "Franklin Gothic ATF", "Franklin Gothic", "Franklin Gothic Book", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
}

/* Keep hover effects */
.post-media-section .wp-block-group.post.is-layout-flow time a:hover,
.post-media-section .wp-block-group.post.is-layout-flow [datetime] a:hover,
.post-media-section .wp-block-group.post.is-layout-flow .wp-block-post-author-name a:hover {
    color: #6a1a38 !important;
}

