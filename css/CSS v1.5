    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
    z-index: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
}

/* Remove any possible top spacing from parent elements */
.cover-fix:before,
.cover-fix:after {
    display: none !important;
}

