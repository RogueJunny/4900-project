/*content block hidden margin and padding */

.no-space {
  margin: 0 !important;
  padding: 0 !important;
}

/* heading text color */
.heading-text-color {
   color: #882346 !important;
}

/* yellow text color */
.yellow-text {
   color: #F3BD48 !important;
}





















/* header stuff */



/* ========== SECTION 1: LOGO STYLES ========== */
.site-logo-padding {
  padding-left: 10% !important;
}

.site-logo-padding img,
.wp-block-site-logo img {
  width: auto !important;
  height: auto !important;
  max-width: 100% !important;
  max-height: 210px !important;
}

/* Responsive logo scaling - progressive reduction with 50% at smallest */
@media (max-width: 1600px) {
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 180px !important;
  }
}

@media (max-width: 1400px) {
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 150px !important;
  }
}

@media (max-width: 1200px) {
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 130px !important;
  }
}

@media (max-width: 992px) {
  .site-logo-padding {
    padding-left: 5% !important;
  }
  
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 110px !important;
  }
}

@media (max-width: 768px) {
  .site-logo-padding {
    padding-left: 0 !important;
    text-align: center !important;
    width: 100% !important;
  }
  
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 105px !important; /* 50% of 210px */
  }
}

@media (max-width: 576px) {
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 90px !important;
  }
}

@media (max-width: 480px) {
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 75px !important;
  }
}

@media (max-width: 400px) {
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 65px !important;
  }
}

@media (max-width: 350px) {
  .site-logo-padding img,
  .wp-block-site-logo img {
    max-height: 55px !important;
  }
}

/* clicking on header created a white box for a second */
.site-logo-padding a:hover {
  outline: none !important;
  border: none !important;
  -webkit-tap-highlight-color: transparent !important;
}

/* ========== SECTION 2: HEADER ROW STYLES ========== */
.head-row-padding {
  padding-right: 100px  !important;
  padding-top: 60px  !important;
  min-width: fit-content !important;
  box-sizing: content-box !important;
}

/* ========== SECTION 3: HEADER TEXT / MENU STYLES ========== */
.header-text {
  background-color: #000000 !important;
  color: #ffffff !important;
  font-size: 1.3rem;
}

.header-text:hover {
  background-color: #000000 !important;
  transition: all 0.3s ease;
}

.header-text a:hover {
  background-color: #000000 !important;  
  color: #F3BD48 !important;    
  text-decoration: none !important;  
  border-bottom: none !important;        
  outline: none !important;
  -webkit-tap-highlight-color: transparent !important; 
  transition: all 0.3s ease;
}

/* submenu text size change */
.header-text .wp-block-navigation__submenu-container a {
  font-size: 1rem !important;
}

/* menu for submenu that arrow icon */
.wp-block-navigation__submenu-icon svg {
  color: #F3BD48  !important;
  fill: #F3BD48 !important;
  stroke: #F3BD48 !important;
}

.wp-block-navigation-item:hover .wp-block-navigation__submenu-icon svg {
  color: #882346 !important;
  fill: #882346 !important;
  stroke: #882346 !important;
  background-color: transparent !important;
  opacity: 1 !important;
  transform: none !important;
  rotate: 0deg !important;
}

.navigation-text {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  align-items: center !important;
  white-space: nowrap !important;
  gap: 20px !important;
}

/* ========== SECTION 4: PARAGRAPH NAVIGATION STYLES ========== */
/* Base styles for all paragraph-navigation elements */
.paragraph-navigation {
  white-space: nowrap !important;
  padding-left: calc(10% - 5px) !important; /* Moved 5px to the left */
  padding-top: 20px !important;
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  gap: 20px !important;
  align-items: center !important;
  width: auto !important;
  box-sizing: border-box !important;
  overflow-x: auto !important;
  overflow-y: hidden !important;
  -webkit-overflow-scrolling: touch !important;
  scrollbar-width: thin !important;
}

/* Style scrollbar for paragraph navigation */
.paragraph-navigation::-webkit-scrollbar {
  height: 4px;
}

.paragraph-navigation::-webkit-scrollbar-track {
  background: #333;
  border-radius: 3px;
}

.paragraph-navigation::-webkit-scrollbar-thumb {
  background: #F3BD48;
  border-radius: 3px;
}

/* Link styles */
.paragraph-navigation a {
  color: #F3BD48;
  text-decoration: none;
  transition: color 0.3s ease-in-out;
  outline: none !important;
  box-shadow: none !important;
  display: inline-block !important;
  white-space: nowrap !important;
  flex-shrink: 0 !important;
}

/* Hover effect */
.paragraph-navigation a:hover {
  color: #ffffff;
}

/* Remove focus styles for all states when clicked */
.paragraph-navigation a:focus,
.paragraph-navigation a:active,
.paragraph-navigation a:focus-visible,
.paragraph-navigation a:focus-within {
  outline: none !important;
  box-shadow: none !important;
  background: transparent !important;
  color: #F3BD48;
}

/* Remove any default browser focus rings */
.paragraph-navigation a::-moz-focus-inner {
  border: 0 !important;
}

/* For mobile tap highlight */
.paragraph-navigation a {
  -webkit-tap-highlight-color: transparent !important;
}

/* Fix search alignment in paragraph navigation - VERTICAL ALIGNMENT FIX */
.paragraph-navigation .wp-block-search {
  align-items: center !important;
  display: inline-flex !important;
  vertical-align: middle !important;
  margin: 0 !important;
  padding: 0 !important;
  position: relative !important;
  top: 0 !important;
  transform: none !important;
}

.paragraph-navigation .wp-block-search__label {
  line-height: normal !important;
  vertical-align: middle !important;
  display: inline-block !important;
}

.paragraph-navigation .wp-block-search::before {
  vertical-align: middle !important;
  display: inline-block !important;
}

.paragraph-navigation .wp-block-search__inside-wrapper {
  vertical-align: middle !important;
  display: inline-flex !important;
}

/* ========== SECTION 5: SEARCH BLOCK STYLES ========== */
/* Target the search block container */
.wp-block-search {
  position: relative !important;
  display: inline-flex !important;
  align-items: center !important;
  width: auto !important;
  background: transparent !important;
  gap: 0 !important;
  flex-shrink: 0 !important;
  vertical-align: middle !important;
}

/* Add magnifying glass emoji BEFORE the search text */
.wp-block-search::before {
  content: "🔍︎" !important;
  font-size: 16px !important;
  color: #ffffff !important;
  background: transparent !important;
  margin-right: 5px !important;
  position: relative !important;
  z-index: 5 !important;
  order: 1 !important;
  display: inline-block !important;
  vertical-align: middle !important;
}

/* Style the label (Search text) */
.wp-block-search__label {
  color: #F3BD48 !important;
  font-size: 1rem !important;
  font-weight: bold !important;
  margin: 0 !important;
  margin-right: 5px !important;
  background: transparent !important;
  white-space: nowrap !important;
  position: relative !important;
  z-index: 5 !important;
  order: 2 !important;
  display: inline-block !important;
  vertical-align: middle !important;
  line-height: normal !important;
}

/* Remove the old after element */
.wp-block-search::after {
  display: none !important;
}

/* Style the inside wrapper (contains input and button) - SMALLER WIDTH */
.wp-block-search .wp-block-search__inside-wrapper {
  display: inline-flex !important;
  align-items: center !important;
  position: relative !important;
  width: 0 !important;
  opacity: 0 !important;
  visibility: hidden !important;
  transition: all 0.4s ease !important;
  background: transparent !important;
  border: none !important;
  margin: 0 !important;
  margin-left: 5px !important;
  flex-shrink: 0 !important;
  order: 3 !important;
  box-shadow: none !important;
  vertical-align: middle !important;
}

/* Show input wrapper on hover - SMALLER WIDTH */
.wp-block-search:hover .wp-block-search__inside-wrapper {
  width: 200px !important;
  opacity: 1 !important;
  visibility: visible !important;
}

/* Style the input field - ADJUSTED FOR SMALLER WIDTH */
.wp-block-search__input {
  width: 100% !important;
  padding: 6px 40px 6px 12px !important;
  border: 1px solid #ccc !important;
  border-radius: 30px !important;
  background: white !important;
  font-size: 13px !important;
  outline: none !important;
  box-shadow: none !important;
  height: 32px !important;
  box-sizing: border-box !important;
}

/* Remove focus shadow/color */
.wp-block-search__input:focus {
  border: 1px solid #999 !important;
  box-shadow: none !important;
  outline: none !important;
}

/* Style the button - INSIDE the search bar - ADJUSTED FOR SMALLER WIDTH */
.wp-block-search__button {
  position: absolute !important;
  right: 5px !important;
  top: 50% !important;
  transform: translateY(-50%) !important;
  background: #000000 !important;
  color: white !important;
  border: none !important;
  border-radius: 25px !important;
  padding: 3px 10px !important;
  margin: 0 !important;
  cursor: pointer !important;
  font-size: 11px !important;
  font-weight: bold !important;
  transition: none !important;
  height: 24px !important;
  line-height: 1 !important;
  width: auto !important;
  z-index: 10 !important;
  outline: none !important;
  -webkit-tap-highlight-color: transparent !important;
}

/* Remove focus outline when button is clicked */
.wp-block-search__button:focus,
.wp-block-search__button:active,
.wp-block-search__button:focus-visible,
.wp-block-search__button:focus-within {
  outline: none !important;
  box-shadow: none !important;
  border: none !important;
  background: #000000 !important;
  color: white !important;
}

/* Remove hover effect completely */
.wp-block-search__button:hover {
  background: #000000 !important;
  color: white !important;
  border: none !important;
  outline: none !important;
}

/* Animation - UPDATED FOR SMALLER WIDTH */
@keyframes expandIn {
  0% {
    width: 0;
    opacity: 0;
  }
  100% {
    width: 200px !important;
    opacity: 1;
  }
}

.wp-block-search:hover .wp-block-search__inside-wrapper {
  animation: expandIn 0.3s ease forwards !important;
}

/* Force the layout to be horizontal */
.wp-block-search,
.wp-block-search > *,
.wp-block-search__inside-wrapper {
  display: inline-flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
}

/* Reset any default positioning */
.wp-block-search__inside-wrapper {
  left: auto !important;
  right: auto !important;
  position: relative !important;
}

/* Remove any focus rings from all elements */
.wp-block-search *:focus {
  outline: none !important;
  box-shadow: none !important;
}

/* ========== SECTION 6: RESPONSIVE SIZING ========== */

/* Large desktop - normal layout */
@media (max-width: 1400px) {
  .site-logo-padding {
    padding-left: 8% !important;
  }
  
  .paragraph-navigation {
    padding-left: calc(5% - 5px) !important;
  }
  
  .header-text {
    font-size: 1.1rem !important;
  }
  
  .navigation-text,
  .paragraph-navigation {
    gap: 15px !important;
  }
}

@media (max-width: 1200px) {
  .site-logo-padding {
    padding-left: 7% !important;
  }
  
  .paragraph-navigation {
    padding-left: calc(3% - 5px) !important;
  }
  
  .head-row-padding {
    padding-right: 40px !important;
    padding-top: 40px !important;
  }
  
  .header-text {
    font-size: 1rem !important;
  }
  
  .navigation-text,
