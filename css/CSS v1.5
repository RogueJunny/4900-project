    width: 180px !important;
  }
  
  @keyframes expandIn {
    0% { width: 0; opacity: 0; }
    100% { width: 180px !important; opacity: 1; }
  }
}

@media (max-width: 992px) {
  .site-logo-padding {
    padding-left: 5% !important;
  }
  
  .paragraph-navigation {
    padding-left: calc(2% - 5px) !important;
  }
  
  .head-row-padding {
    padding-right: 30px !important;
    padding-top: 35px !important;
  }
  
  .header-text {
    font-size: 0.9rem !important;
  }
  
  .navigation-text,
  .paragraph-navigation {
    gap: 10px !important;
  }
  
  .wp-block-search__label {
    font-size: 0.85rem !important;
  }
  
  .wp-block-search::before {
    font-size: 13px !important;
  }
  
  .wp-block-search:hover .wp-block-search__inside-wrapper {
    width: 170px !important;
  }
  
  @keyframes expandIn {
    0% { width: 0; opacity: 0; }
    100% { width: 170px !important; opacity: 1; }
  }
}

/* Tablet - stack elements and INSTANTLY REMOVE padding */
@media (max-width: 768px) {
