/* Code for offset image backgrounds */
.img-offset-box {
  position: relative;
  display: inline-block;
}

.img-offset-box::before {
  content: '';
  position: absolute;
  top: 75px;    /* how far down the background box sits */
  left: 75px;   /* how far right the background box sits */
  width: 100%;
  height: 100%;

  /* ↓ ADD YOUR BACKGROUND IMAGE URL HERE ↓ */
  background-image: url('https://i.imgur.com/uYl5x4N.png');
  /* ↑ ADD YOUR BACKGROUND IMAGE URL HERE ↑ */

  background-size: cover;
  background-position: center;
  background-color: #4a90d9; /* fallback color if no image loads */

  z-index: -1;
  border-radius: 4px;
}

.img-offset-box img {
  position: relative;
  display: block;
  z-index: 1;
}
