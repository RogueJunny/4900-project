		<wp:meta_value><![CDATA[/* contact us form */

/* Main container - bigger and more prominent */
.contact-us-form {
    max-width: 900px;
    margin: 50px auto;
}

/* Form background and spacing - more padding */
.contact-us-form .wpcf7-form {
    background: #ffffff;
    padding: 60px;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    
    /* Fixed background image for the form */
    background-image: url('https://i.imgur.com/2HWAQ4a.png');
    background-position: top center;
    background-repeat: no-repeat;
    background-size: 100% auto;  /* This makes the image stretch full width */
    /* Alternative options: */
    /* background-size: cover; */  /* This would cover the entire form */
    /* background-size: contain; */ /* This shows the full image but might not fill width */
}

/* Form labels - slightly larger */
.contact-us-form label {
    display: block;
    margin-bottom: 10px;
    color: #1e293b;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.3px;
}

/* Wrapper for input fields to handle background images better */
.contact-us-form .wpcf7-form-control-wrap {
    display: block;
    position: relative;
    width: 100%;
}

/* All input fields - bigger and more spacious */
.contact-us-form input[type="text"],
.contact-us-form input[type="email"],
.contact-us-form textarea {
    width: 100%;
    padding: 16px 20px;
    margin-bottom: 32px;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    font-size: 16px;
    transition: all 0.2s ease;
    background: #f8fafc;
    box-sizing: border-box;
    
    /* Fixed background image for input values */
    background-image: url('https://i.imgur.com/oNsj5wK.png');
    background-position: 98% center;  /* Position at 98% from left */
    background-repeat: no-repeat;
    background-size: 24px 24px;  /* Slightly larger and better proportioned */
}

/* Remove background from file input as it doesn't need it */
.contact-us-form input[type="file"] {
    width: 100%;
    padding: 30px;
    margin-bottom: 32px;
    border: 3px dashed #cbd5e1;
    border-radius: 16px;
    background: #f8fafc;  /* Removed the background image from file input */
    color: #475569;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s ease;
}

/* Input focus effect - more prominent */
.contact-us-form input[type="text"]:focus,
.contact-us-form input[type="email"]:focus,
.contact-us-form textarea:focus {
    border-color: #3b82f6;
    background: #ffffff;
    background-image: url('https://i.imgur.com/oNsj5wK.png');  /* Keep background on focus */
    background-position: 98% center;
    background-repeat: no-repeat;
    background-size: 24px 24px;
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
    outline: none;
}

/* Make textarea taller */
.contact-us-form textarea {
    min-height: 150px;
    resize: vertical;
}

/* File upload styling - bigger drop zone */
.contact-us-form input[type="file"]:hover {
    border-color: #3b82f6;
    background: #f0f9ff;
}

/* Submit button - bigger and more prominent */
.contact-us-form input[type="submit"] {
    background: #3b82f6;
    color: white;
    padding: 18px 32px;
    border: none;
    border-radius: 12px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
    letter-spacing: 0.5px;
    margin-top: 10px;
}

.contact-us-form input[type="submit"]:hover {
    background: #2563eb;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
}

.contact-us-form input[type="submit"]:active {
    transform: translateY(0);
}

/* Error messages - adjusted spacing for bigger form */
.contact-us-form .wpcf7-not-valid-tip {
    color: #dc2626;
    font-size: 14px;
    margin-top: -26px;
    margin-bottom: 20px;
    font-weight: 400;
}

/* Success message - bigger */
.contact-us-form .wpcf7-mail-sent-ok {
    background: #10b981;
    color: white;
    padding: 16px 24px;
    border-radius: 12px;
    margin-top: 30px;
    border: none;
    font-size: 16px;
    text-align: center;
    font-weight: 500;
}

/* Akismet privacy link - adjusted spacing */
.contact-us-form .wpcf7-form p:last-child {
    font-size: 13px;
    color: #64748b;
    text-align: center;
    margin-top: 32px;
    margin-bottom: 0;
    padding-top: 10px;
    border-top: 1px solid #e2e8f0;
}

.contact-us-form .wpcf7-form a {
    color: #3b82f6;
    text-decoration: none;
    font-weight: 500;
}

.contact-us-form .wpcf7-form a:hover {
    text-decoration: underline;
}

/* Mobile friendly - adjusted for larger design */
@media (max-width: 768px) {
    .contact-us-form {
        max-width: 95%;
        margin: 30px auto;
    }
    
    .contact-us-form .wpcf7-form {
        padding: 30px;
        background-size: 150% auto;  /* Adjust for mobile */
    }
    
    .contact-us-form input[type="text"],
    .contact-us-form input[type="email"],
    .contact-us-form textarea {
        padding: 14px 18px;
        background-size: 20px 20px;  /* Slightly smaller on mobile */
        background-position: 97% center;
    }
    
    .contact-us-form input[type="file"] {
        padding: 20px;
    }
    
    .contact-us-form input[type="submit"] {
        padding: 16px 28px;
        font-size: 17px;
    }
}

/* Remove line breaks if any */
.contact-us-form .wpcf7-form > br {
    display: none;
}

/* Make the form feel even more spacious on large screens */
@media (min-width: 1200px) {
    .contact-us-form {
        max-width: 1000px;
    }
    
    .contact-us-form .wpcf7-form {
        padding: 70px;
    }
}









































.full-page-three-column {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 30px;
    width: 100%;
    max-width: 100%;
