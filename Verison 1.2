    padding: 40px;
    box-sizing: border-box;
}

/* Image styling */
.full-page-three-column > :first-child img,
.full-page-three-column > :last-child img {
    width: 100%;
    height: 2000px; 
    object-fit: cover;  /* Crops image to fit without distortion */
    object-position: center;  /* Centers the crop */
    border-radius: 16px;
    display: block;
}]]></wp:meta_value>
