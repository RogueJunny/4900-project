<!-- /wp:spacer -->

<!-- wp:paragraph {"align":"center","style":{"typography":{"fontSize":"2.5rem"}},"fontFamily":"franklin-gothic-atf"} -->
<p class="has-text-align-center has-franklin-gothic-atf-font-family" style="font-size:2.5rem">Welcome to Brooklyn College CIS Connect!</p>
<!-- /wp:paragraph -->

<!-- wp:paragraph {"align":"center","style":{"typography":{"fontSize":"1.5rem"}},"fontFamily":"system-sans-serif"} -->
<p class="has-text-align-center has-system-sans-serif-font-family" style="font-size:1.5rem">Stay in the know with recent updates and improvements to Brooklyn College CIS Connect—all listed below. While you're here, be sure to explore the navigation menu, where you'll find curated resources, career tools, study materials, and more.</p>
<!-- /wp:paragraph -->

<!-- wp:spacer {"height":"50px"} -->
<div style="height:50px" aria-hidden="true" class="wp-block-spacer"></div>
<!-- /wp:spacer -->

